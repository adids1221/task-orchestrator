# --- BUILD ARTIFACTS ---
# We ignore generated code because it's derived from .proto files
packages/generated/
dist/
build/
coverage/

# --- DEPENDENCIES ---
# We ignore the heavy folders, but the lock files stay in Git!
node_modules/
.pnp
.pnp.*

# --- SECRETS (VERY IMPORTANT) ---
.env
*.env
.env.local
.env*.local

# --- OS/IDE ---
.DS_Store
.vscode/

# --- NEXT.JS ---
.next/
out/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- LOGS/DEBUG ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*