// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  lastName  String
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("TODO")
  taskNumber  String   @unique
  createdAt         DateTime @default(now()) // This is your "Initial Timestamp"
  lastStatusChange  DateTime @default(now()) // When the current status started
  updatedAt         DateTime @updatedAt      // Auto-updates on any change
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  history     TaskHistory[]
}

model TaskHistory {
  id              String   @id @default(uuid())
  taskId          String
  oldStatus       String
  newStatus       String
  changedAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id])
}